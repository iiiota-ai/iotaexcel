# Input file or directory. convert/codegen use Excel; decode uses .bytes.
input=./excels

# Output directory.
output=./out

# convert output format: csv/json/bin.
convertFormat=bin

# decode output format: csv/json.
decodeFormat=json

# Scan input directories recursively.
recursive=true

# Optional sheet filter: sheet name or 1-based sheet index. Empty means all sheets.
sheet=

# Overwrite existing output files.
overwrite=false

# Export target fields: client/server/both.
target=both

# Check whether ref<T> target sheets and keys exist.
checkRef=false

# Strict schema validation. Currently defaults to true.
strict=true

# Whether .bytes includes field names and type names.
selfDescribing=true

# Excel schema file or directory for decoding non-self-describing .bytes.
schemaInput=./excels

# Print decoded .bytes structure to stdout.
print=false

# decode --print mode: verbose/concise.
printMode=verbose

# codegen target language: csharp/go/cpp/java/javascript/python.
lang=csharp

# Generated C# namespace, Go/Java package, or C++ namespace. JavaScript ignores this option.
# Defaults: DataConfig for C#/C++, dataconfig for Go/Java.
package=DataConfig

# Log level: debug/info/warn/error.
logLevel=info

# Log format: text/json.
logFormat=text

# Optional log file path. Empty means stderr only.
logFile=
